# Agora ConvoAI - Video Avatar Profile Configuration
# Copy this file to .env and fill in your VIDEO_* values
# Used by react-video-client-avatar (automatically sends ?profile=video)

# =====================================================
# IMPORTANT: VIDEO PROFILE REQUIREMENTS
# =====================================================
# - All credentials MUST have VIDEO_ prefix
# - NO fallback to base variables when using ?profile=video
# - react-video-client-avatar automatically uses this profile
# - Missing VIDEO_* variables will cause BAD REQUEST errors

# =====================================================
# AGORA CREDENTIALS (Video Profile) - REQUIRED
# =====================================================

# VIDEO_APP_ID - Agora application identifier for video profile
# Get from: https://console.agora.io/project-management
# Help: https://docs.agora.io/en/conversational-ai/get-started/manage-agora-account
VIDEO_APP_ID=

# VIDEO_AGENT_AUTH_HEADER - Authentication header for Agora Agent REST API
# Get from: https://console.agora.io/restful-api
# Help: https://docs.agora.io/en/conversational-ai/rest-api/restful-authentication
# Format: Basic <base64(customer_id:customer_secret)>
VIDEO_AGENT_AUTH_HEADER=

# VIDEO_APP_CERTIFICATE - Security certificate for token generation (optional for testing)
# Get from: Same project page as APP_ID
# Leave empty to skip token generation
VIDEO_APP_CERTIFICATE=

# =====================================================
# LLM SETTINGS (Video Profile) - REQUIRED
# =====================================================

# VIDEO_LLM_API_KEY - API key for language model
# Get from: https://platform.openai.com/settings/organization/api-keys
VIDEO_LLM_API_KEY=

# VIDEO_LLM_MODEL - OpenAI model to use (optional, defaults to gpt-4o-mini)
# VIDEO_LLM_MODEL=gpt-4o-mini

# VIDEO_LLM_URL - OpenAI API endpoint (optional, defaults to OpenAI)
# VIDEO_LLM_URL=https://api.openai.com/v1/chat/completions

# =====================================================
# TTS SETTINGS (Video Profile) - REQUIRED
# =====================================================

# VIDEO_TTS_VENDOR - Text-to-speech provider
# Required: rime, elevenlabs, openai, or cartesia
VIDEO_TTS_VENDOR=

# VIDEO_TTS_KEY - API key for your chosen TTS vendor
# Get from your vendor:
# - Rime: https://rime.ai/
# - ElevenLabs: https://elevenlabs.io/
# - OpenAI: https://platform.openai.com/
# - Cartesia: https://cartesia.ai/
VIDEO_TTS_KEY=

# VIDEO_TTS_VOICE_ID - Voice/speaker identifier for your chosen vendor
# Examples by vendor:
# - Rime: astra, deedee, marsh
# - ElevenLabs: Get from https://elevenlabs.io/ voice library
# - OpenAI: alloy, echo, fable, onyx, nova, shimmer
# - Cartesia: Get from https://cartesia.ai/ voice library
VIDEO_TTS_VOICE_ID=

# =====================================================
# AVATAR SETTINGS (Video Profile) - REQUIRED
# =====================================================

# VIDEO_AVATAR_VENDOR - Avatar video provider
# Required: heygen or anam
VIDEO_AVATAR_VENDOR=

# VIDEO_AVATAR_API_KEY - API key from avatar provider
# Get from:
# - HeyGen: https://www.heygen.com/
# - Anam AI: https://www.anam.ai/
VIDEO_AVATAR_API_KEY=

# VIDEO_AVATAR_ID - Specific avatar identifier from provider console
# Get from: Your avatar provider dashboard (avatar ID/name)
VIDEO_AVATAR_ID=

# =====================================================
# ASR SETTINGS (Video Profile) - OPTIONAL
# =====================================================

# VIDEO_ASR_VENDOR - Speech recognition vendor (optional, defaults to ares)
# VIDEO_ASR_VENDOR=ares

# VIDEO_ASR_LANGUAGE - Language code for speech recognition (optional, defaults to en-US)
# VIDEO_ASR_LANGUAGE=en-US

# =====================================================
# AGENT BEHAVIOR (Video Profile) - OPTIONAL
# =====================================================

# VIDEO_VAD_SILENCE_DURATION_MS - Voice activity detection silence duration (optional)
# VIDEO_VAD_SILENCE_DURATION_MS=300

# VIDEO_ENABLE_AIVAD - Enable AI voice activity detection (optional, defaults to true)
# VIDEO_ENABLE_AIVAD=true

# VIDEO_IDLE_TIMEOUT - Agent idle timeout in seconds (optional, defaults to 120)
# VIDEO_IDLE_TIMEOUT=120

# VIDEO_MAX_HISTORY - Maximum conversation history messages (optional, defaults to 32)
# VIDEO_MAX_HISTORY=32

# =====================================================
# PROMPTS (Video Profile) - OPTIONAL
# =====================================================

# VIDEO_DEFAULT_GREETING - Initial greeting message (optional)
# VIDEO_DEFAULT_GREETING=hi there

# VIDEO_DEFAULT_PROMPT - System prompt for agent behavior (optional)
# VIDEO_DEFAULT_PROMPT=You are a virtual companion. The user can both talk and type to you and you will be sent text. Say you can hear them if asked. They can also see you as a digital human. Keep responses to around 10 to 20 words or shorter. Be upbeat and try and keep conversation going by learning more about the user.

# VIDEO_DEFAULT_FAILURE_MESSAGE - Error message shown to user (optional)
# VIDEO_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

# =====================================================
# VENDOR-SPECIFIC OPTIONS (Video Profile) - OPTIONAL
# =====================================================

# Rime TTS options (if using VIDEO_TTS_VENDOR=rime)
# VIDEO_RIME_MODEL_ID=mistv2
# VIDEO_RIME_LANG=eng
# VIDEO_RIME_SAMPLING_RATE=16000
# VIDEO_RIME_SPEED_ALPHA=1.0

# ElevenLabs TTS options (if using VIDEO_TTS_VENDOR=elevenlabs)
# VIDEO_ELEVENLABS_MODEL=eleven_flash_v2_5
# VIDEO_ELEVENLABS_STABILITY=0.5

# OpenAI TTS options (if using VIDEO_TTS_VENDOR=openai)
# VIDEO_OPENAI_TTS_MODEL=tts-1

# Cartesia TTS options (if using VIDEO_TTS_VENDOR=cartesia)
# VIDEO_CARTESIA_MODEL=sonic-3

# HeyGen avatar options (if using VIDEO_AVATAR_VENDOR=heygen)
# VIDEO_HEYGEN_QUALITY=high
# VIDEO_HEYGEN_ACTIVITY_IDLE_TIMEOUT=120

# Deepgram ASR (if using VIDEO_ASR_VENDOR=deepgram instead of ares)
# VIDEO_DEEPGRAM_KEY=
# VIDEO_DEEPGRAM_MODEL=nova-3
# VIDEO_DEEPGRAM_LANGUAGE=en

# =====================================================
# DEBUG OPTIONS (Video Profile) - OPTIONAL
# =====================================================

# VIDEO_ENABLE_CURL_DUMP - Enable verbose curl debug logging (optional, defaults to false)
# VIDEO_ENABLE_CURL_DUMP=false

# =====================================================
# ENDPOINT OVERRIDES (Video Profile) - ADVANCED
# =====================================================

# VIDEO_AGENT_ENDPOINT - Override Agora agent endpoint (optional)
# VIDEO_AGENT_ENDPOINT=https://api.agora.io/api/conversational-ai-agent/v2/projects

# Anam endpoints (used automatically when VIDEO_AVATAR_VENDOR=anam)
# ANAM_AGENT_ENDPOINT=https://api-test.agora.io/api/conversational-ai-agent/v2/projects
