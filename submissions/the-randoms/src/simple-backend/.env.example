# Agora ConvoAI Configuration Template
# Copy this file to .env and fill in your values

# =====================================================
# PROFILE-BASED CONFIGURATION SYSTEM
# =====================================================
# This project uses profile-prefixed environment variables.
# Each profile is completely independent with <PROFILE>_<VARIABLE> naming.
#
# Default profiles required by clients:
# - VOICE_* variables (used by react-voice-client)
# - VIDEO_* variables (used by react-video-client-avatar)
#
# Profile names are case-insensitive (server normalizes to lowercase)
# - "VOICE", "voice", or "Voice" all work identically
#
# Clients default to uppercase but you can override via "Server Profile" field

# =====================================================
# PIPELINE MODE (Optional — Agent Builder)
# =====================================================
# Set PIPELINE_ID to use an Agent Builder pipeline instead of
# inline LLM/TTS/ASR config. When set, only APP_ID, APP_CERTIFICATE,
# and PIPELINE_ID are needed — no LLM/TTS/ASR keys required.
# Supports profile prefix: VOICE_PIPELINE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PIPELINE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# VOICE PROFILE (react-voice-client default)
# =====================================================
# Architecture: TTS + LLM mode with Rime TTS

# Agora credentials
VOICE_APP_ID=
VOICE_APP_CERTIFICATE=
# VOICE_AGENT_AUTH_HEADER=  # Not needed when APP_CERTIFICATE is set — falls back to v007 token auth
VOICE_AGENT_ENDPOINT=https://api.agora.io/api/conversational-ai-agent/v2/projects

# LLM settings
VOICE_LLM_API_KEY=
VOICE_LLM_MODEL=gpt-4o-mini
VOICE_LLM_URL=https://api.openai.com/v1/chat/completions

# TTS settings - Rime TTS
VOICE_TTS_VENDOR=rime
VOICE_TTS_KEY=
VOICE_TTS_VOICE_ID=astra  # Options: astra, deedee, marsh
VOICE_RIME_MODEL_ID=mistv2
VOICE_RIME_LANG=eng
VOICE_RIME_SAMPLING_RATE=16000
VOICE_RIME_SPEED_ALPHA=1.0

# ASR settings
VOICE_ASR_VENDOR=ares
VOICE_ASR_LANGUAGE=en-US

# Agent behavior
VOICE_VAD_SILENCE_DURATION_MS=300
VOICE_ENABLE_AIVAD=true
VOICE_IDLE_TIMEOUT=120
VOICE_MAX_HISTORY=32

# Prompts
VOICE_DEFAULT_GREETING=Hey there, I am Quiz Master Bella, would you like me to quiz you on capital cities?
VOICE_DEFAULT_PROMPT=You are Bella, a quiz master who asks capital city questions. You can hear the user clearly through voice. Keep responses under 20 words and immediately ask the next question after announcing the result.
VOICE_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

# =====================================================
# VOICE_MLLM PROFILE (Optional - Gemini Live MLLM)
# =====================================================
# Architecture: MLLM mode with built-in TTS (no separate TTS vendor)

# VOICE_MLLM_APP_ID=
# VOICE_MLLM_APP_CERTIFICATE=
# VOICE_MLLM_AGENT_AUTH_HEADER=  # Not needed when APP_CERTIFICATE is set
# VOICE_MLLM_AGENT_ENDPOINT=https://api.agora.io/api/conversational-ai-agent/v2/projects

# MLLM settings
# VOICE_MLLM_ENABLE_MLLM=true
# VOICE_MLLM_MLLM_VENDOR=vertexai
# VOICE_MLLM_MLLM_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025
# VOICE_MLLM_MLLM_ADC_CREDENTIALS_STRING=<json_credentials_as_string>
# VOICE_MLLM_MLLM_PROJECT_ID=<gcp_project_id>
# VOICE_MLLM_MLLM_LOCATION=us-central1

# Transcription (built into MLLM)
# VOICE_MLLM_MLLM_TRANSCRIBE_AGENT=true
# VOICE_MLLM_MLLM_TRANSCRIBE_USER=true

# ASR settings (still required for VAD)
# VOICE_MLLM_ASR_VENDOR=ares
# VOICE_MLLM_ASR_LANGUAGE=en-US

# Agent behavior
# VOICE_MLLM_VAD_SILENCE_DURATION_MS=300
# VOICE_MLLM_ENABLE_AIVAD=true
# VOICE_MLLM_IDLE_TIMEOUT=120
# VOICE_MLLM_MAX_HISTORY=32

# Prompts
# VOICE_MLLM_DEFAULT_GREETING=Hi there
# VOICE_MLLM_DEFAULT_PROMPT=You are a virtual companion...
# VOICE_MLLM_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

# =====================================================
# VOICE_MLLM_OPENAI PROFILE (Optional - OpenAI Realtime MLLM)
# =====================================================
# Architecture: MLLM mode with OpenAI Realtime (no separate TTS vendor)

# VOICE_MLLM_OPENAI_APP_ID=
# VOICE_MLLM_OPENAI_APP_CERTIFICATE=
# VOICE_MLLM_OPENAI_AGENT_AUTH_HEADER=  # Not needed when APP_CERTIFICATE is set

# MLLM settings
# VOICE_MLLM_OPENAI_ENABLE_MLLM=true
# VOICE_MLLM_OPENAI_MLLM_VENDOR=openai
# VOICE_MLLM_OPENAI_MLLM_MODEL=gpt-4o-realtime-preview
# VOICE_MLLM_OPENAI_MLLM_API_KEY=sk-...
# VOICE_MLLM_OPENAI_MLLM_STYLE=openai
# VOICE_MLLM_OPENAI_MLLM_VOICE=alloy

# ASR settings (still required for VAD)
# VOICE_MLLM_OPENAI_ASR_VENDOR=ares
# VOICE_MLLM_OPENAI_ASR_LANGUAGE=en-US

# Agent behavior
# VOICE_MLLM_OPENAI_VAD_SILENCE_DURATION_MS=300
# VOICE_MLLM_OPENAI_ENABLE_AIVAD=true

# Prompts
# VOICE_MLLM_OPENAI_DEFAULT_GREETING=Hi there
# VOICE_MLLM_OPENAI_DEFAULT_PROMPT=You are a friendly assistant.
# VOICE_MLLM_OPENAI_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

# =====================================================
# VIDEO PROFILE (react-video-client-avatar default)
# =====================================================
# Architecture: TTS + LLM mode with avatar (HeyGen or Anam)

# Agora credentials
VIDEO_APP_ID=
VIDEO_APP_CERTIFICATE=
# VIDEO_AGENT_AUTH_HEADER=  # Not needed when APP_CERTIFICATE is set — falls back to v007 token auth

# LLM settings
VIDEO_LLM_API_KEY=
VIDEO_LLM_MODEL=gpt-4o-mini
VIDEO_LLM_URL=https://api.openai.com/v1/chat/completions

# TTS settings - ElevenLabs
VIDEO_TTS_VENDOR=elevenlabs
VIDEO_TTS_KEY=
VIDEO_TTS_VOICE_ID=  # Get from https://elevenlabs.io/
VIDEO_ELEVENLABS_MODEL=eleven_flash_v2_5
VIDEO_ELEVENLABS_STABILITY=0.5
VIDEO_TTS_SAMPLE_RATE=24000

# ASR settings
VIDEO_ASR_VENDOR=ares
VIDEO_ASR_LANGUAGE=en-US

# Avatar settings - Choose either HeyGen or Anam
# For HeyGen:
VIDEO_AVATAR_VENDOR=heygen
VIDEO_AVATAR_API_KEY=
VIDEO_AVATAR_ID=  # e.g., Graham_Chair_Sitting_public
VIDEO_HEYGEN_QUALITY=high
VIDEO_HEYGEN_ACTIVITY_IDLE_TIMEOUT=120

# For Anam (production):
# VIDEO_AVATAR_VENDOR=anam
# VIDEO_AVATAR_API_KEY=
# VIDEO_AVATAR_ID=  # Get from Anam dashboard

# Agent behavior
VIDEO_VAD_SILENCE_DURATION_MS=300
VIDEO_ENABLE_AIVAD=true
VIDEO_IDLE_TIMEOUT=120
VIDEO_MAX_HISTORY=32

# Prompts
VIDEO_DEFAULT_GREETING=Hey there, I am Quiz Master Bella, would you like me to quiz you on capital cities?
VIDEO_DEFAULT_PROMPT=You are Bella, a quiz master who asks capital city questions. You can hear the user clearly through voice. Keep responses under 20 words and immediately ask the next question after announcing the result.
VIDEO_DEFAULT_FAILURE_MESSAGE=Sorry, something went wrong

# Note: Anam is now in production and uses the same standard endpoint as HeyGen.
# Simply set VIDEO_AVATAR_VENDOR=anam in the VIDEO profile above.

# =====================================================
# TTS VENDOR OPTIONS
# =====================================================
# TTS_VENDOR can be: rime, elevenlabs, openai, or cartesia
#
# Rime TTS options:
#   RIME_MODEL_ID=mistv2
#   RIME_LANG=eng
#   RIME_SAMPLING_RATE=16000 or 24000
#   RIME_SPEED_ALPHA=1.0
#   TTS_VOICE_ID options: astra, deedee, marsh
#
# ElevenLabs TTS options:
#   ELEVENLABS_MODEL=eleven_flash_v2_5
#   ELEVENLABS_STABILITY=0.5
#   ELEVENLABS_SAMPLE_RATE=24000
#   TTS_VOICE_ID: Get from https://elevenlabs.io/
#
# OpenAI TTS options:
#   OPENAI_TTS_MODEL=tts-1
#   TTS_VOICE_ID options: alloy, echo, fable, onyx, nova, shimmer
#
# Cartesia TTS options:
#   CARTESIA_MODEL=sonic-3
#   TTS_VOICE_ID: Get from https://cartesia.ai/

# =====================================================
# MCP SETTINGS (Optional - enable external tool calling)
# =====================================================
# See: https://github.com/AgoraIO-Conversational-AI/server-mcp
#
# MCP (Model Context Protocol) allows the agent to call external tools
# during conversation. The endpoint must be publicly accessible.
#
# MCP_SERVERS is a JSON array of server configs:
# - name: Unique identifier (alphanumeric, max 48 chars)
# - endpoint: Public URL of the MCP server
# - transport: Must be "streamable_http"
# - headers: Optional auth headers
# - allowed_tools: ["*"] for all, or list specific tool names
#
# Example with mem0 (persistent memory):
# VOICE_MCP_SERVERS=[{"name":"mem0","endpoint":"https://your-tunnel.trycloudflare.com/mcp","transport":"streamable_http","headers":{"Authorization":"Token m0-xxx"},"allowed_tools":["*"]}]
#
# For local MCP servers, use Cloudflare Tunnel to make them publicly accessible:
#   cloudflared tunnel --url http://localhost:8090
#
# Multiple servers:
# VOICE_MCP_SERVERS=[{"name":"mem0","endpoint":"https://tunnel1.trycloudflare.com/mcp","transport":"streamable_http","headers":{"Authorization":"Token m0-xxx"},"allowed_tools":["*"]},{"name":"weather","endpoint":"https://tunnel2.trycloudflare.com/mcp","transport":"streamable_http","allowed_tools":["get_weather"]}]

# =====================================================
# CUSTOM LLM SERVER (Optional — advanced)
# =====================================================
# A Custom LLM server sits between Agora ConvoAI and your LLM provider,
# giving you full control over prompts, RAG, tool calling, and response formatting.
#
# See: https://github.com/AgoraIO-Conversational-AI/server-custom-llm
#
# To use a custom LLM server:
# 1. Deploy one of the server implementations (Python, Node.js, or Go)
# 2. Set LLM_URL to your server's endpoint
# 3. Set LLM_VENDOR=custom to receive turn_id and timestamp in requests
#
# Example:
# VOICE_LLM_URL=https://your-custom-llm.example.com/chat/completions
# VOICE_LLM_API_KEY=your-openai-key
# VOICE_LLM_VENDOR=custom
# VOICE_LLM_STYLE=openai
#
# Endpoints available:
#   /chat/completions          - Basic LLM proxy with streaming
#   /rag/chat/completions      - RAG-enhanced with knowledge base injection
#   /audio/chat/completions    - Multimodal audio response
#
# LLM_STYLE options: openai (default), gemini, anthropic, dify
# LLM_VENDOR: set to "custom" for custom LLM servers (adds turn_id + timestamp),
#             "azure" for Azure OpenAI. Omit to use default behavior.
#
# Greeting behavior (applies to any LLM mode):
# GREETING_MODE: single_every (greet every user join, default behavior),
#                single_first (greet only the first user who joins)
# VOICE_GREETING_MODE=single_every

# =====================================================
# DEBUG OPTIONS
# =====================================================
# ENABLE_CURL_DUMP=false  # Set to true to dump curl commands to /tmp
